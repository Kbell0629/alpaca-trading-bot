__pycache__/
*.pyc
.env

# Runtime data files (regenerated by scripts, contain no source config).
# dashboard.html is the RUNTIME copy written by update_dashboard.py into
# DATA_DIR (which defaults to BASE_DIR locally). The LIVE source is at
# templates/dashboard.html. Ignore the generated copy so stale snapshots
# don't get re-committed.
dashboard.html
dashboard_data.json
capital_status.json
trade_journal.json
scorecard.json
notification_log.json
notification_queue.json
learned_weights.json
email_queue.json

# Runtime strategy files (auto-deployed per-symbol files)
# But NOT the template configs (copy_trading.json, wheel_strategy.json, trailing_stop.json)
strategies/trailing_stop_*.json
strategies/mean_reversion_*.json
strategies/breakout_*.json
strategies/wheel_*.json
!strategies/wheel_strategy.json
strategies/.deploying

# Multi-user auth
users.db
users.db-journal
users.db-wal
users.db-shm
users/

# Additional runtime files
accounts.json
guardrails.json
auto_deployer_config.json
email_queue.json.lock

# Data dir for Railway volume (if ever present locally)
data/

.claude/worktrees/

# Test artefacts
.pytest_cache/
.coverage
htmlcov/
